# === Database ===
DATABASE_URL=postgresql+asyncpg://dermassist:dermassist_dev@localhost:5432/dermassist

# === Authentication — JWT (local accounts) ===
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace_with_64_hex_chars_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=480

# === Authentication — Google OAuth (optional; leave blank to disable) ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# === VLM provider ===
VLM_PROVIDER=openai
VLM_ENDPOINT=https://api.openai.com/v1
VLM_API_KEY=sk-...
VLM_MODEL=gpt-4o-mini

# === Service info ===
SERVICE_NAME=dermassist-vn
LOG_LEVEL=INFO
BASE_URL=http://localhost:8000

# === Production-only hints (set in Railway dashboard, NOT here) ===
# These vars need *production* values when deployed; the dev defaults
# above are for localhost only. Do not commit prod values.
#
# BASE_URL=https://your-app.up.railway.app
# LOG_LEVEL=INFO
# VLM_PROVIDER=openai
# VLM_MODEL=gpt-4o-mini
# VLM_ENDPOINT=https://api.openai.com/v1
#
# JWT_SECRET_KEY: generate fresh per env (do NOT reuse the dev secret)
# OPENAI_API_KEY: production OpenAI key with gpt-4o-mini access
# GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET / GOOGLE_REDIRECT_URI:
#   optional; redirect URI must match Google Cloud Console exactly
