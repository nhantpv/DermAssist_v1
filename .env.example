# === Database ===
DATABASE_URL=postgresql+asyncpg://dermassist:dermassist_dev@localhost:5432/dermassist

# === Authentication ===
JWT_SECRET_KEY=replace_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# === VLM Service ===
# In dev: point to local vLLM or Modal endpoint
# In prod (Modal): set by Modal env
VLM_ENDPOINT=http://localhost:8001/v1
VLM_MODEL=qwen2.5-vl-7b-int4
VLM_TIMEOUT_SECONDS=60

# === Storage ===
IMAGE_UPLOAD_DIR=/tmp/dermassist-uploads
MAX_IMAGE_SIZE_MB=10

# === RAG ===
EMBEDDING_MODEL=intfloat/multilingual-e5-small
RAG_TOP_K=5
RAG_RRF_K=60

# === Logging ===
LOG_LEVEL=INFO
LOG_FORMAT=json

# === Demo / Rate limiting ===
DEMO_USER_RPM=10
REGULAR_USER_RPM=60

# === Modal (production only) ===
# MODAL_TOKEN_ID=
# MODAL_TOKEN_SECRET=
