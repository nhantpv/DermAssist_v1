# .env.production.template — values to set in the Railway dashboard, NOT here.
# This file is committed for documentation; real secrets live in Railway only.
#
# Set each one under: Railway project → web service → Variables → New Variable.
# DATABASE_URL is auto-injected when you attach the Postgres service; do not
# set it manually.

# === Required ===

# Generate fresh per environment. Do NOT reuse the dev secret.
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=

# OpenAI API key for the gpt-4o-mini VLM call (TIP-009).
OPENAI_API_KEY=

# Public base URL Railway assigned (or your custom domain). Set after the
# first successful deploy. Used for absolute URLs in emails/OAuth callbacks.
BASE_URL=

# === Logging / behavior ===

LOG_LEVEL=INFO

# VLM provider config (TIP-009). Don't change MODEL — eval numbers are
# pinned to gpt-4o-mini in TIP-012.
VLM_PROVIDER=openai
VLM_MODEL=gpt-4o-mini
VLM_ENDPOINT=https://api.openai.com/v1

# === Optional: Google OAuth ===
# Leave unset to fall back to demo/demo local login. If set, you ALSO
# need to add the Railway URL to "Authorized redirect URIs" in Google
# Cloud Console for the same OAuth client. Trailing slash matters.

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
